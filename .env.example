# 强口令机制：缺 .env 或密码仍为 CHANGE_ME → 拒绝启动
# 复制本文件为 .env 并修改所有 CHANGE_ME 占位符
#
# Docker passwords —— 复制为 .env 后必须替换为强口令 (≥12位, 大小写+数字+符号)
# docker-compose.yml 已去除弱默认值, 未设置这些变量将拒绝启动 (SEC-003/DEP-006)
INFLUX_USER=admin
INFLUX_PASS=CHANGE_ME__influx_Str0ng!Pass
MYSQL_ROOT_PASS=CHANGE_ME__mysql_root_Str0ng!Pass
MYSQL_USER=gps_user
MYSQL_PASS=CHANGE_ME__mysql_Str0ng!Pass
REDIS_PASS=CHANGE_ME__redis_Str0ng!Pass

# JWT (HS256 for Demo, RS256 for production with proper key file)
JWT_SECRET=CHANGE_ME__random_64_hex__openssl_rand_-hex_32
JWT_ALGORITHM=HS256

# Database URLs —— 口令部分须与上方保持一致
DATABASE_URL=mysql+pymysql://gps_user:CHANGE_ME__mysql_Str0ng!Pass@localhost:3306/green_power_sentinel?charset=utf8mb4
INFLUX_URL=http://localhost:8086
REDIS_URL=redis://:CHANGE_ME__redis_Str0ng!Pass@localhost:6379/0
